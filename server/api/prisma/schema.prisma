generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    String     @id @default(cuid())
  firstName  String
  lastName String
  password String
  email String  @unique
  words Word[]
}


model Word {
  @@unique([word, userId])
  id          String   @id @default(cuid())
  word        String
  type        WordType
  description String
  extraNotes  String?

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  examples    String
  synonyms    String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum WordType {
  NOUN
  VERB
  ADJECTIVE
  ADVERB
}